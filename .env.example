# Development mode — set to "true" for local dev, unset or "false" for production
DEVELOPMENT=true

# --- Local development (used when DEVELOPMENT=true) ---
REDIS_HOST_DEV=localhost
REDIS_PORT=6379

POSTGRES_DB_DEV=app_db
POSTGRES_USER_DEV=app
POSTGRES_PASSWORD_DEV=app_pw

# --- Production (used when DEVELOPMENT is unset or false) ---
REDIS_HOST_PROD=
REDIS_PASSWORD_PROD=
REDIS_URL_PROD=

POSTGRES_DB_PROD=
POSTGRES_USER_PROD=
POSTGRES_PASSWORD_PROD=

# -- Frontend URL
ALLOWED_ORIGIN=localhost:5173

# -- Backend API URL
PUBLIC_API_URL=localhost:8000

# --- General ---
OPENAI_API_KEY=

GCS_BUCKET_NAME=storage-papers

# Suppresses HuggingFace tokenizer parallelism warning
TOKENIZERS_PARALLELISM=False
